# Server Configuration
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3030
# Comma-separated list of additional CORS origins (optional)
ALLOWED_ORIGINS=

# Database (use these when running Docker: docker compose -f docker-compose.dev.yml up -d)
MONGODB_URI=mongodb://localhost:27017/agrismart
REDIS_URL=redis://localhost:6379

# Authentication
# IMPORTANT: Generate a secure random string of at least 32 chars in production.
# Example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-secure-random-string-min-32-chars
JWT_EXPIRE=7d

# External APIs - REAL-TIME (Weather, Market, Location)
# Weather: Open-Meteo is used by default (no key). Optional: set OPENWEATHER_API_KEY for OpenWeatherMap.
OPENWEATHER_API_KEY=
# Market: Data.gov.in / AgMarkNet for market price prediction (same key).
DATA_GOV_IN_API_KEY=
AGMARKNET_API_KEY=
DATA_GOV_API_KEY=
# Location: OpenStreetMap (Nominatim) is used for geocoding - no API key required.
# GOOGLE_MAPS_API_KEY=

# AI Services (Optional - for enhanced features)
# Perplexity: used for AgriGPT chat and crop recommendation when set. Key must start with pplx-
PERPLEXITY_API_KEY=
PERPLEXITY_TIMEOUT=15000
OPENAI_API_KEY=
GOOGLE_AI_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Messaging (Twilio) - leave blank if not using
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Payment Gateways (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
UPI_MERCHANT_ID=

# IoT/MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Feature toggles
TF_ENABLED=false
USE_GPU=false
PYTHON_PATH=python3
FEATURE_REALTIME_ANALYTICS=true
FEATURE_ML_PREDICTIONS=true
FEATURE_EXTERNAL_APIS=true
FEATURE_CACHING=true
ENABLE_PERPLEXITY=true
ENABLE_LOCAL_LLM=true
ENABLE_RULE_ENGINE=true
OLLAMA_HOST=http://localhost:11434
LOCAL_LLM_MODEL=llama2
LOCAL_LLM_TIMEOUT=20000
ALWAYS_USE_FALLBACK=false
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000

# Observability
COMMIT_SHA=
BUILD_ID=
DEPLOYED_AT=
VERBOSE_HTTP_LOGS=false

# Cache Settings
CACHE_DURATION=300000
